#!/bin/sh
#
# 1. Strip Co-authored-by / Signed-off-by trailers added by AI editors.
# 2. Run GrumPHP commit-msg hook.
#

COMMIT_MSG_FILE="$1"

sed -i '/^Co-authored-by:/d' "$COMMIT_MSG_FILE"
sed -i '/^Signed-off-by:/d' "$COMMIT_MSG_FILE"

# GrumPHP commit-msg hook
GIT_USER=$(git config user.name)
GIT_EMAIL=$(git config user.email)
DIFF=$(git -c diff.mnemonicprefix=false -c diff.noprefix=false --no-pager diff --raw -r -p -m -M --full-index --no-color --staged | cat)

export GRUMPHP_GIT_WORKING_DIR="$(git rev-parse --show-toplevel)"

(cd "./" && printf "%s\n" "${DIFF}" | exec 'vendor/bin/grumphp' 'git:commit-msg' "--git-user='$GIT_USER'" "--git-email='$GIT_EMAIL'" "$COMMIT_MSG_FILE")
